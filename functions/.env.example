# Variables d'environnement des Cloud Functions (copier en functions/.env).
# Bucket Cloud Storage des imports bruts / exports (BUILD_KIT §3, §9).
IMPORTS_BUCKET=nt360
# Bucket des sauvegardes Firestore planifiées (F8). Laissé vide = même bucket que les imports
# (comportement historique). Pour ISOLER les sauvegardes (rétention/lifecycle propres, hors du
# blast-radius des imports) : créer un bucket dédié + sa règle de rétention, PUIS pointer dessus.
# BACKUP_BUCKET=nt360-backups
# App Check : « true » pour EXIGER un jeton App Check valide sur tous les callables. NE PAS activer
# tant que la clé reCAPTCHA v3 n'est pas déployée au client (voir docs/app-check.md), sinon tous les
# appels seraient rejetés. En CI, piloté par la variable de dépôt APPCHECK_ENFORCE.
APPCHECK_ENFORCE=false
# RECOMPUTE DIFFÉRÉ (PERFORMANCE des boutons d'action). Par défaut, chaque enregistrement/mise à jour
# (commande, facture, opp, BC, alias, objectifs…) attend un recompute COMPLET des agrégats AVANT de
# répondre → le clic peut rester bloqué plusieurs dizaines de secondes (jusqu'au timeout de 60 s).
# En définissant RECOMPUTE_REGION, ces mutations RÉPONDENT EN ~ms (elles déposent une demande dans
# config/recomputeRequest) et le recompute s'exécute HORS du chemin de réponse via le trigger Firestore
# `onRecomputeRequest` ; le front rafraîchit les summaries en temps réel quelques secondes plus tard.
# VALEUR = une région de fonction CO-LOCALISÉE avec la base Firestore NOMMÉE (FIRESTORE_DATABASE=nt360).
# Un trigger Firestore doit tourner dans une région compatible avec la région de la base. Ex. si la base
# nt360 est en europe-west, mettre europe-west1/3/9 (selon disponibilité). Vérifier la région exacte de
# la base dans la console Firestore, PUIS définir ci-dessous et redéployer (déploie onRecomputeRequest).
# RECOMPUTE_REGION=europe-west1
# (FIRESTORE_DATABASE : base Firestore nommée ciblée par les fonctions ; défaut « nt360 » si absent.)
# FIRESTORE_DATABASE=nt360
