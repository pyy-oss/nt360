# Variables d'environnement des Cloud Functions (copier en functions/.env).
# Bucket Cloud Storage des imports bruts / exports (BUILD_KIT §3, §9).
IMPORTS_BUCKET=nt360
# Bucket des sauvegardes Firestore planifiées (F8). Laissé vide = même bucket que les imports
# (comportement historique). Pour ISOLER les sauvegardes (rétention/lifecycle propres, hors du
# blast-radius des imports) : créer un bucket dédié + sa règle de rétention, PUIS pointer dessus.
# BACKUP_BUCKET=nt360-backups
# App Check : « true » pour EXIGER un jeton App Check valide sur tous les callables. NE PAS activer
# tant que la clé reCAPTCHA v3 n'est pas déployée au client (voir docs/app-check.md), sinon tous les
# appels seraient rejetés. En CI, piloté par la variable de dépôt APPCHECK_ENFORCE.
APPCHECK_ENFORCE=false
