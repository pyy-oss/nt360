rules_version = '2';
service cloud.firestore {
  match /databases/{db}/documents {
    // --- RBAC opposable : la matrice de droits est lue côté serveur ---
    // Le front ne fait jamais autorité (BUILD_KIT §8).
    function signedIn() { return request.auth != null; }
    function role() { return request.auth.token.role; }
    function matrix() { return get(/databases/$(db)/documents/config/permissions).data.matrix; }
    function level(m) { return role() == 'direction' ? 'write' : matrix()[role()][m]; }
    function canRead(m)  { return signedIn() && level(m) in ['read','write']; }
    function canWrite(m) { return signedIn() && level(m) == 'write'; }

    // Module d'appartenance d'un agrégat summaries/{id}, d'après le préfixe d'identifiant.
    // Applique le cloisonnement de la matrice AUSSI aux summaries (sinon un rôle sans droit
    // sur un module — ex. commercial sur fournisseurs — pourrait lire ses agrégats).
    function summaryModule(id) {
      // Marge (par ligne / agrégée / par entité) → accès « Rentabilité » requis. Testé AVANT les
      // préfixes plus larges (overview/clients/domaines) qui matcheraient aussi ces identifiants.
      return id.matches('overviewMargin.*') ? 'rentabilite'
        // Marge reportée sur N+1 (isolée) → accès « Rentabilité » requis (avant atterrissage.*).
        : id.matches('atterrissageMargin.*') ? 'rentabilite'
        : id.matches('overview.*') ? 'overview'
        : id.matches('facturation.*') ? 'facturation'
        : id.matches('receivables.*') ? 'facturation'
        : id.matches('cashflow.*') ? 'facturation'
        // Prévision cash avancée (scénarios/tension) : même assiette que cashflow → « facturation ».
        : id.matches('cashScenario.*') ? 'facturation'
        : id.matches('billingTrend.*') ? 'facturation'
        : id.matches('rentabilite.*') ? 'rentabilite'
        // Marge par entité isolée → accès « Rentabilité » requis (avant les règles clients/domaines).
        : id.matches('clientsMargin.*') ? 'rentabilite'
        : id.matches('domainesMargin.*') ? 'rentabilite'
        : id.matches('pipeline.*') ? 'pipeline'
        : id.matches('ams.*') ? 'pipeline'
        : id.matches('suppliers.*') ? 'fournisseurs'
        : id.matches('atterrissage.*') ? 'overview'
        : id.matches('backlog.*') ? 'backlog'
        : id.matches('clients.*') ? 'clients'
        : id.matches('domaines.*') ? 'domaines'
        : id.matches('commandes.*') ? 'overview'
        // Alertes DÉRIVÉES DE LA MARGE (marge négative / achats > vente) isolées → « Rentabilité »
        // requis (avant alerts.* qui matcherait aussi « alertsMargin »).
        : id.matches('alertsMargin.*') ? 'rentabilite'
        : id.matches('alerts.*') ? 'overview'
        : id.matches('dataQuality.*') ? 'overview'
        : id.matches('qualityHistory.*') ? 'overview'
        : id.matches('trends.*') ? 'overview'
        : id.matches('news.*') ? 'overview'
        // Plan de relance : CLOISONNÉ par module (le montant d'une créance ne fuite pas hors facturation).
        : id.matches('relancesCreances.*') ? 'facturation'
        : id.matches('relancesBc.*') ? 'fournisseurs'
        : id.matches('relancesJalons.*') ? 'backlog'
        // FALLBACK = DENY (module inexistant → canRead false pour tout rôle non-direction). Fail-CLOSED :
        // un futur agrégat non explicitement classé (ex. une nouvelle marge) ne fuite pas par défaut.
        : '__deny__';
    }

    // Collections sources : écriture réservée aux Functions (Admin SDK, contourne les rules).
    // orders/* porte la marge (mb) par ligne → lecture réservée à « Rentabilité ». Les vues non-marge
    // (FP 360°, Commandes) lisent les chunks commandesRows (sans marge) ; le serveur lit via Admin SDK.
    match /orders/{id}        { allow read: if canRead('rentabilite'); allow write: if false; }
    match /invoices/{id}      { allow read: if canRead('facturation');  allow write: if false; }
    match /projectSheets/{id} { allow read: if canRead('pnlprojet');    allow write: if false; }
    // Marge des fiches affaire (coût/vente/marge/%MB) → accès « Rentabilité » requis.
    match /projectSheetsMargin/{id} { allow read: if canRead('rentabilite'); allow write: if false; }

    // Opportunités : seules les saisies (source == 'saisie') sont modifiables par le client.
    match /opportunities/{id} {
      allow read: if canRead('pipeline');
      // Création d'une saisie manuelle uniquement.
      allow create: if canWrite('pipeline') && request.resource.data.source == 'saisie';
      // Modif/suppression réservées aux opps DÉJÀ saisies (resource.data) : on ne peut pas
      // « détourner » une opp importée en basculant sa source vers 'saisie' côté client.
      allow update: if canWrite('pipeline') && resource.data.source == 'saisie' && request.resource.data.source == 'saisie';
      allow delete: if canWrite('pipeline') && resource.data.source == 'saisie';
    }

    // Lignes BC : le client ne peut faire évoluer QUE le statut.
    match /bcLines/{id} {
      allow read: if canRead('bc');
      // Le client ne peut faire évoluer QUE le statut, et seulement vers une valeur du cycle.
      allow update: if canWrite('bc')
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        && request.resource.data.status in ['a_emettre', 'emis', 'livre', 'facture', 'solde'];
    }

    match /creditLines/{id}   { allow read: if canRead('fournisseurs'); allow write: if canWrite('fournisseurs'); }
    // Jalons de facturation (échéancier prévisionnel par projet) : lisibles par qui voit le backlog ;
    // écrits uniquement par la Cloud Function setBillingMilestones (direction/PMO).
    match /billingMilestones/{id} { allow read: if canRead('backlog');  allow write: if false; }
    match /objectives/{id}    { allow read: if canRead('objectifs');    allow write: if canWrite('objectifs'); }

    // Agrégats : écrits par les Functions, lus selon le module d'appartenance de l'agrégat.
    match /summaries/{id}     { allow read: if canRead(summaryModule(id)); allow write: if false; }
    // Chunks des commandes matérialisées (module « overview », comme summaries/commandes).
    match /commandesRows/{id} { allow read: if canRead('overview');       allow write: if false; }
    // Chunks de MARGE par ligne → accès « Rentabilité » requis (confidentialité).
    match /commandesRowsMargin/{id} { allow read: if canRead('rentabilite'); allow write: if false; }

    // Config : la matrice de droits est éditée UNIQUEMENT via le callable setPermissions (schéma
    // validé + auditLog) — jamais en écriture directe (une matrice malformée casserait level() pour
    // tous). Lecture par tout utilisateur connecté (nécessaire à la résolution de niveau côté front).
    match /config/permissions { allow read: if signedIn();              allow write: if false; }
    // config/notifications contient l'URL de webhook (sensible) → lecture réservée aux habilitations.
    match /config/notifications { allow read: if canWrite('habilitations'); allow write: if false; }
    // Table d'alias de normalisation clients : éditée via setClientAliases, lue par l'écran Admin.
    match /config/clientAliases { allow read: if canWrite('habilitations'); allow write: if false; }
    // Overlays d'annulation (statut « Annulée » persistant, hors delta) : ids exclus des agrégats,
    // édités via setCancellation. Lisibles AU NIVEAU DU MODULE (cloisonnement) — les commandes à
    // « overview », les factures à « facturation » (pas de fuite de libellé facturation ailleurs).
    match /config/cancelOrders   { allow read: if canRead('overview');    allow write: if false; }
    match /config/cancelInvoices { allow read: if canRead('facturation'); allow write: if false; }
    // Repli config/* : ALLOWLIST fail-closed (les docs sensibles ont leur propre règle ci-dessus ;
    // un futur doc config/* non listé n'est PAS lisible par défaut). Inclut les référentiels éditables
    // (projectManagers, businessUnits), les taux de change (fxRates) et la config ClickUp NON sensible
    // (enabled/teamId/listId ; le token vit dans Secret Manager, jamais ici) — tous lus par le front.
    match /config/{id}        { allow read: if signedIn() && id in ['alerts', 'projection', 'periods', 'fiscal', 'projectManagers', 'businessUnits', 'fxRates', 'clickup']; allow write: if false; }

    match /auditLog/{id}      { allow read: if canWrite('habilitations'); allow write: if false; }
    match /opsLog/{id}        { allow read: if canWrite('habilitations'); allow write: if false; }
    // Erreurs client (observabilité front) : lisibles par les administrateurs ; écrites uniquement
    // par la Cloud Function logClientError (jamais en direct).
    match /errorLog/{id}      { allow read: if canWrite('habilitations'); allow write: if false; }
    match /imports/{id}       { allow read: if canWrite('habilitations'); allow write: if false; }
    match /users/{uid}        { allow read: if canWrite('habilitations') || request.auth.uid == uid; allow write: if false; }
  }
}
