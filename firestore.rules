rules_version = '2';
service cloud.firestore {
  match /databases/{db}/documents {
    // --- RBAC opposable : la matrice de droits est lue côté serveur ---
    // Le front ne fait jamais autorité (BUILD_KIT §8).
    function signedIn() { return request.auth != null; }
    // Claim NAMESPACÉ (nt360Role) : projet Firebase PARTAGÉ avec une autre app → un claim générique
    // `role` serait commun aux deux (un `role:direction` de l'app sœur escaladerait ici). On ne lit que nt360Role.
    function role() { return request.auth.token.nt360Role; }
    // Utilisateur PROVISIONNÉ nt360 (porte le claim namespacé) — distinct de signedIn() : un compte
    // authentifié par l'app SŒUR satisfait signedIn() mais n'a pas de nt360Role. Sert à cloisonner les
    // lectures « connecté » (matrice, référentiels) pour ne rien exposer à l'app sœur.
    function isNt360() { return signedIn() && request.auth.token.nt360Role != null; }
    function matrix() { return get(/databases/$(db)/documents/config/permissions).data.matrix; }
    function level(m) { return role() == 'direction' ? 'write' : matrix()[role()][m]; }
    function canRead(m)  { return signedIn() && level(m) in ['read','write']; }
    function canWrite(m) { return signedIn() && level(m) == 'write'; }

    // Drapeau du module Contrats de maintenance (ADR-009). ABSENT ⇒ éteint (fail-closed) : aucune
    // collection mnt_* n'est alors lisible, même pour un rôle porteur du droit `maintenance`. C'est
    // la garantie « à drapeau éteint, l'ERP est STRICTEMENT celui d'avant ».
    function mntEnabled() {
      return exists(/databases/$(db)/documents/config/mntFeature)
        && get(/databases/$(db)/documents/config/mntFeature).data.enabled == true;
    }
    // Drapeau du module Partenariats & Certifications (ADR-P01), même patron fail-closed que mntEnabled.
    function parEnabled() {
      return exists(/databases/$(db)/documents/config/parFeature)
        && get(/databases/$(db)/documents/config/parFeature).data.enabled == true;
    }

    // --- Sécurité par ENREGISTREMENT (Lot 2 « niveau Salesforce ») : PROPRIÉTAIRE + HIÉRARCHIE ---
    // OWD (Org-Wide Default) par objet, édité par setRecordAccess (config/recordAccess). Défaut = « public »
    // (le doc peut ne pas exister → comportement historique inchangé). Passé à « private », un enregistrement
    // n'est visible que de son propriétaire, de sa ligne hiérarchique (via `visibleTo` dénormalisée) et des
    // administrateurs. `visibleTo` = chaîne ascendante du propriétaire, matérialisée par les callables — d'où
    // un filtrage O(1) (`uid in resource.data.visibleTo`) sans traversée récursive (impossible en rules).
    function owdPrivate(obj) {
      return exists(/databases/$(db)/documents/config/recordAccess)
        && get(/databases/$(db)/documents/config/recordAccess).data[obj] == 'private';
    }
    // Administrateur d'enregistrements = voit TOUT quel que soit l'OWD (direction ou droit « habilitations »).
    function isRecordAdmin() { return signedIn() && (role() == 'direction' || level('habilitations') == 'write'); }
    // Autorisation de lecture d'un enregistrement gouverné : droit du module ET (OWD public, ou admin, ou
    // appartenance à la ligne hiérarchique du propriétaire). En requête (list), la contrainte serveur
    // `where('visibleTo','array-contains', uid)` garantit le dernier terme ; le front l'ajoute sous OWD privé.
    function canSeeRecord(m, obj) {
      return canRead(m) && (!owdPrivate(obj) || isRecordAdmin() || (request.auth.uid in resource.data.visibleTo));
    }

    // Module d'appartenance d'un agrégat summaries/{id}, d'après le préfixe d'identifiant.
    // Applique le cloisonnement de la matrice AUSSI aux summaries (sinon un rôle sans droit
    // sur un module — ex. commercial sur fournisseurs — pourrait lire ses agrégats).
    function summaryModule(id) {
      // Marge (par ligne / agrégée / par entité) → accès « Rentabilité » requis. Testé AVANT les
      // préfixes plus larges (overview/clients/domaines) qui matcheraient aussi ces identifiants.
      return id.matches('overviewMargin.*') ? 'rentabilite'
        // Marge reportée sur N+1 (isolée) → accès « Rentabilité » requis (avant atterrissage.*).
        : id.matches('atterrissageMargin.*') ? 'rentabilite'
        // Objectifs annuels (cible CAS/CAF, écart, proba) ISOLÉS → accès « objectifs » requis (avant
        // atterrissage.* qui est overview). Un rôle sans droit « objectifs » ne lit pas les cibles.
        : id.matches('atterrissageObjectifs.*') ? 'objectifs'
        : id.matches('overview.*') ? 'overview'
        : id.matches('facturation.*') ? 'facturation'
        : id.matches('receivables.*') ? 'facturation'
        : id.matches('cashflow.*') ? 'facturation'
        // Prévision cash avancée (scénarios/tension) : même assiette que cashflow → « facturation ».
        : id.matches('cashScenario.*') ? 'facturation'
        : id.matches('billingTrend.*') ? 'facturation'
        // Pré-facturation consolidée (DO Lot 4) : expose TJM/CA par ressource → accès « Rentabilité ».
        : id.matches('preBilling.*') ? 'rentabilite'
        // Reconnaissance de revenu (DO Lot 4b) : montant/facturé + FAE/PCA par affaire → accès « Rentabilité ».
        : id.matches('recognition.*') ? 'rentabilite'
        : id.matches('rentabilite.*') ? 'rentabilite'
        // Marge par entité isolée → accès « Rentabilité » requis (avant les règles clients/domaines).
        : id.matches('clientsMargin.*') ? 'rentabilite'
        : id.matches('domainesMargin.*') ? 'rentabilite'
        : id.matches('pipeline.*') ? 'pipeline'
        : id.matches('ams.*') ? 'pipeline'
        : id.matches('oppFunnel.*') ? 'pipeline'
        // Glissement des deals (DC Lot 4) : agrégat par catégorie/commercial, même assiette que le funnel → 'pipeline'.
        // Sans cette branche, oppSlippage tombait en '__deny__' → bandeau glissement invisible pour les non-direction.
        : id.matches('oppSlippage.*') ? 'pipeline'
        : id.matches('suppliers.*') ? 'fournisseurs'
        : id.matches('atterrissage.*') ? 'overview'
        : id.matches('backlog.*') ? 'backlog'
        : id.matches('clients.*') ? 'clients'
        : id.matches('domaines.*') ? 'domaines'
        : id.matches('commandes.*') ? 'overview'
        // Alertes DÉRIVÉES DE LA MARGE (marge négative / achats > vente) isolées → « Rentabilité »
        // requis (avant alerts.* qui matcherait aussi « alertsMargin »).
        : id.matches('alertsMargin.*') ? 'rentabilite'
        // Alertes CLOISONNÉES par module (données sensibles du module concerné) — testées AVANT
        // alerts.* qui matcherait ces identifiants. Cf. audit P0-C (fuite inter-modules).
        : id.matches('alertsFacturation.*') ? 'facturation'
        : id.matches('alertsFournisseurs.*') ? 'fournisseurs'
        : id.matches('alertsBacklog.*') ? 'backlog'
        : id.matches('alertsBc.*') ? 'bc'
        : id.matches('alertsPipeline.*') ? 'pipeline'
        : id.matches('alerts.*') ? 'overview'
        : id.matches('dataQuality.*') ? 'overview'
        : id.matches('qualityHistory.*') ? 'overview'
        : id.matches('trends.*') ? 'overview'
        // Actualité CLOISONNÉE par module (bulletins/recos sensibles) — AVANT news.* qui matcherait
        // ces identifiants. Cf. audit P0-C (fuite créances/DSO, fournisseurs, backlog).
        : id.matches('newsFacturation.*') ? 'facturation'
        : id.matches('newsFournisseurs.*') ? 'fournisseurs'
        : id.matches('newsBacklog.*') ? 'backlog'
        : id.matches('newsBc.*') ? 'bc'
        : id.matches('newsPipeline.*') ? 'pipeline'
        // Curation LLM de la veille (scores de pertinence par TYPE, aucune donnée sensible) → overview.
        // Explicite (bien que news.* le couvrirait) pour lever toute ambiguïté.
        : id.matches('newsCuration.*') ? 'overview'
        : id.matches('news.*') ? 'overview'
        // Plan de relance : CLOISONNÉ par module (le montant d'une créance ne fuite pas hors facturation).
        : id.matches('relancesCreances.*') ? 'facturation'
        : id.matches('relancesBc.*') ? 'fournisseurs'
        : id.matches('relancesJalons.*') ? 'backlog'
        // Diagnostic qualité de l'intégration ClickUp → réservé aux habilitations (carte direction).
        : id.matches('clickupHealth.*') ? 'habilitations'
        // Suivi BC ⇄ ClickUp (avancement achat + retards) → module fournisseurs.
        : id.matches('clickupBc.*') ? 'fournisseurs'
        // Délais & échéances ClickUp (carte Suivi Backlog, par PM/statut) → module backlog (pmo).
        : id.matches('clickupDelays.*') ? 'backlog'
        // Charge par Project Manager (carte Commandes + filtre PM transverse) → lisible à overview.
        : id.matches('pms.*') ? 'overview'
        // Scores de risque des contrats de maintenance (Lot 5) → module 'maintenance'. Le drapeau
        // ajoute un second verrou dans le match /summaries (mnt_risque illisible drapeau éteint, C10).
        // Agrégats du module Partenariats (CA par constructeur, quotas, alertes) → module 'partenariats'.
        // Le drapeau parEnabled() ajoute un second verrou dans le match /summaries (par_* illisible drapeau éteint).
        : id.matches('par_.*') ? 'partenariats'
        : id.matches('mnt_risque.*') ? 'maintenance'
        // Flux du centre de surveillance (Lot 5, ADR-026) → même module + verrou drapeau que mnt_risque.
        : id.matches('mnt_surveillance.*') ? 'maintenance'
        // Snapshot MRR/ARR quotidien (Lot 5b, ADR-043) → même module + verrou drapeau que mnt_risque.
        : id.matches('mnt_mrr.*') ? 'maintenance'
        // FALLBACK = DENY (module inexistant → canRead false pour tout rôle non-direction). Fail-CLOSED :
        // un futur agrégat non explicitement classé (ex. une nouvelle marge) ne fuite pas par défaut.
        : '__deny__';
    }

    // Collections sources : écriture réservée aux Functions (Admin SDK, contourne les rules).
    // orders/* porte la marge (mb) par ligne → lecture réservée à « Rentabilité ». Les vues non-marge
    // (FP 360°, Commandes) lisent les chunks commandesRows (sans marge) ; le serveur lit via Admin SDK.
    match /orders/{id}        { allow read: if canRead('rentabilite'); allow write: if false; }
    match /invoices/{id}      { allow read: if canRead('facturation');  allow write: if false; }
    match /projectSheets/{id} { allow read: if canRead('pnlprojet');    allow write: if false; }
    // Marge des fiches affaire (coût/vente/marge/%MB) → accès « Rentabilité » requis.
    match /projectSheetsMargin/{id} { allow read: if canRead('rentabilite'); allow write: if false; }

    // Opportunités : LECTURE seule côté client ; toute écriture passe par les callables
    // (upsert/patch/deleteOpportunity, Admin SDK) qui VALIDENT (stage/amount/probabilité bornés),
    // AUDITENT (auditLog) et JOURNALISENT les transitions (oppHistory → funnel). Une écriture SDK
    // directe contournerait tout cela et pourrait, via une opp gagnée (stage 6) réconciliée au carnet
    // (mergeCommandes), corrompre le CAS/client d'une commande sans aucune trace. Donc write:false.
    match /opportunities/{id} {
      // Sécurité par enregistrement : sous OWD « private » (opportunities), seuls propriétaire + hiérarchie
      // + admins lisent. Sous « public » (défaut), tout rôle « pipeline » lit (comportement historique).
      allow read: if canSeeRecord('pipeline', 'opportunities');
      allow write: if false;
    }
    // Historique des transitions d'étape (Lot C) : ACCÈS 100% SERVEUR. Écrit par les Functions
    // (recordOppTransition, Admin SDK) et relu UNIQUEMENT côté serveur pour bâtir le funnel (summary).
    // La lecture directe est FERMÉE (read:false) : sous OWD « private », `canRead('pipeline')` aurait
    // laissé fuir client/AM/montant des transitions d'opps hors périmètre (audit RBAC). Aucun écran ne
    // lit oppHistory directement (le funnel vient du summary), donc pas de régression.
    match /oppHistory/{id} { allow read: if false; allow write: if false; }
    // Journal des changements de D Prev (slippage) : écrit par l'Admin SDK, dérivé dans summaries/oppSlippage.
    // Callable-only comme oppHistory (aucun écran ne le lit — la vue vient du summary) → read/write client refusés.
    match /oppDateHistory/{id} { allow read: if false; allow write: if false; }

    // Objet COMPTE (Account 360) + CONTACTS rattachés : entité relationnelle stable clé sur le nom
    // client canonique. Lecture par qui voit le carnet (overview) ; écriture via callables (upsert/
    // deleteAccount/Contact, Admin SDK, droit « pipeline », validés + audités) → write:false.
    // Sécurité par enregistrement : les contacts SUIVENT l'OWD des comptes (leur visibleTo = celui du compte).
    match /accounts/{id} { allow read: if canSeeRecord('overview', 'accounts'); allow write: if false; }
    match /contacts/{id} { allow read: if canSeeRecord('overview', 'accounts'); allow write: if false; }

    // Activités & tâches (Lot 3) : ACCÈS 100% PAR CALLABLE (Admin SDK). La lecture directe est fermée —
    // listActivities applique la visibilité par enregistrement côté serveur (évite index composite +
    // cadrage client). L'écriture passe par upsert/deleteActivity (validés, audités). Donc read/write:false.
    match /activities/{id} { allow read: if false; allow write: if false; }
    // Approbations (Lot 4) : idem, accès 100% par callable (submit/decide/listApprovals) — la visibilité
    // et le contrôle de l'approbateur sont appliqués serveur. Lecture/écriture directes fermées.
    match /approvals/{id} { allow read: if false; allow write: if false; }
    // Rapports self-service (Lot 6) : définitions de rapport, accès 100% par callable (run/save/list/
    // deleteReport). L'exécution reste cadrée par la visibilité de chacun. Lecture/écriture directes fermées.
    match /reports/{id} { allow read: if false; allow write: if false; }
    // FICHE D'AFFAIRE : accès 100% PAR CALLABLE (create/update/advance/reject/get/listFiches, Admin SDK).
    // La lecture directe est FERMÉE car la fiche porte des champs CONFIDENTIELS (provisions, autres frais,
    // prix de revient, marge, % MB, seuil) qui doivent être MASQUÉS côté serveur pour le PM et tout rôle
    // sans droit « rentabilité » (presentFor) — une lecture SDK directe contournerait ce masquage. Le
    // journal (history/*) est append-only, écrit uniquement par les Functions. Donc read/write:false.
    match /fiches/{id} {
      allow read: if false; allow write: if false;
      match /history/{h} { allow read: if false; allow write: if false; }
    }
    // BULLETIN HEBDO « Hot Topics Opérations » : commentaires / points clés non confidentiels →
    // lecture par qui voit le cockpit (« overview ») ; écriture 100% par callable (upsertOpsBulletin,
    // direction/PMO, validé + audité) → write:false côté client.
    match /opsBulletins/{id} { allow read: if canRead('overview'); allow write: if false; }
    // Clés API (Lot 7) : SECRET (hash de clé) — jamais lisible/écrivable côté client. Gérées par callables
    // (create/revoke/listApiKeys, direction) ; vérifiées côté serveur par l'endpoint HTTP `api`.
    match /apiKeys/{id} { allow read: if false; allow write: if false; }
    // Consultants / ressources (Lot 11 DirOps) : accès 100% par callable (upsert/delete/listConsultants).
    // Le coût (CJM) est masqué serveur sauf droit « rentabilite ». Lecture/écriture directes fermées.
    match /consultants/{id} { allow read: if false; allow write: if false; }
    // Affectations / plan de charge (Lot 12 DirOps) : accès 100% par callable (upsert/delete/staffingPlan).
    match /assignments/{id} { allow read: if false; allow write: if false; }
    // CRA / temps constaté (Lot 15 DirOps) : accès 100% par callable (upsert/delete/timesheetKpis).
    match /timesheets/{id} { allow read: if false; allow write: if false; }
    // Vivier / recrutement (Lot 16 DirOps) : accès 100% par callable (upsert/delete/listCandidates).
    match /candidates/{id} { allow read: if false; allow write: if false; }

    // Lignes BC : le client ne peut faire évoluer QUE le statut.
    match /bcLines/{id} {
      allow read: if canRead('bc');
      // Le client ne peut faire évoluer QUE le statut, et seulement vers une valeur du cycle.
      allow update: if canWrite('bc')
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        && request.resource.data.status in ['a_emettre', 'emis', 'livre', 'facture', 'solde'];
    }

    // Écriture INTERDITE au client : toute mutation passe par le callable upsertCreditLine (valide +
    // journalise auditLog). Une écriture SDK directe contournerait la traçabilité opposable. Cf. audit.
    match /creditLines/{id}   { allow read: if canRead('fournisseurs'); allow write: if false; }
    // Factures fournisseur RÉELLES (ADR-P21) — source du solde SOA sous drapeau. Écriture via callable (upsert/deleteSupplierInvoice).
    match /supplierInvoices/{id} { allow read: if canRead('fournisseurs'); allow write: if false; }
    // Jalons de facturation (échéancier prévisionnel par projet) : lisibles par qui voit le backlog ;
    // écrits uniquement par la Cloud Function setBillingMilestones (direction/PMO).
    match /billingMilestones/{id} { allow read: if canRead('backlog');  allow write: if false; }
    // Objectifs annuels : lisibles par qui a le droit « objectifs » ; écrits uniquement par les Cloud
    // Functions upsertObjective/deleteObjective (validation des cibles + auditLog). Écriture SDK directe
    // fermée → plus d'objectif posé sans contrôle ni journal, cohérent avec creditLines/billingMilestones.
    match /objectives/{id}    { allow read: if canRead('objectifs');    allow write: if false; }

    // Agrégats : écrits par les Functions, lus selon le module d'appartenance de l'agrégat. Le conjoint
    // « maintenance ⇒ drapeau allumé » est TOUJOURS vrai pour les summaries existants (summaryModule ≠
    // 'maintenance') → comportement inchangé ; il n'ajoute le double verrou du drapeau qu'à mnt_risque (C3/C10).
    // Le verrou DRAPEAU utilise le PRÉFIXE d'id (regex bon marché) plutôt qu'un 2ᵉ/3ᵉ appel de
    // summaryModule() (grand ternaire coûteux) : un summary de module gaté porte toujours son préfixe
    // (mnt_* / par_*). Évite de dépasser la limite Firestore de 1000 évaluations d'expression par requête.
    // par_ca porte le CA constructeur (volume d'achat fournisseur) — donnée CONFIDENTIELLE : SECOND verrou
    // `rentabilite` (comme les summaries *Margin), en plus du droit `partenariats` + drapeau (ADR-P07). La
    // condition est bon marché (comparaison d'id ; canRead('rentabilite') n'est évalué que pour par_ca).
    match /summaries/{id}     { allow read: if canRead(summaryModule(id)) && (!id.matches('mnt_.*') || mntEnabled()) && (!id.matches('par_.*') || parEnabled()) && (!id.matches('par_ca.*') || canRead('rentabilite')); allow write: if false; }
    // Chunks des commandes matérialisées (module « overview », comme summaries/commandes).
    match /commandesRows/{id} { allow read: if canRead('overview');       allow write: if false; }
    // Chunks de MARGE par ligne → accès « Rentabilité » requis (confidentialité).
    match /commandesRowsMargin/{id} { allow read: if canRead('rentabilite'); allow write: if false; }

    // --- Module Contrats de maintenance (mnt_) : DOUBLE verrou = drapeau ALLUMÉ ET droit `maintenance` ---
    // Écriture toujours par les callables (Admin SDK), comme toute collection ici. Drapeau éteint ⇒
    // mntEnabled() faux ⇒ aucune lecture, quel que soit le rôle : l'ERP reste celui d'avant (C10).
    match /mnt_contrats/{id}       { allow read: if mntEnabled() && canRead('maintenance'); allow write: if false; }
    match /mnt_engagementsSla/{id} { allow read: if mntEnabled() && canRead('maintenance'); allow write: if false; }
    match /mnt_tickets/{id}        { allow read: if mntEnabled() && canRead('maintenance'); allow write: if false; }
    match /mnt_interventions/{id}  { allow read: if mntEnabled() && canRead('maintenance'); allow write: if false; }
    match /mnt_evenementsSla/{id}  { allow read: if mntEnabled() && canRead('maintenance'); allow write: if false; }
    // Versions immuables de contrat (Lot 10b, ADR-P24) : historique append-only, écrit par callable
    // (upsertMntContrat/import, Admin SDK). Lecture gatée drapeau+droit maintenance, écriture cliente refusée.
    match /mnt_contratsVersions/{id} { allow read: if mntEnabled() && canRead('maintenance'); allow write: if false; }
    // Abonnements de surveillance PAR UTILISATEUR (Lot 5, ADR-026) : chaque utilisateur ne lit QUE son
    // propre doc (id = uid). Écriture via le callable setMntWatch (Admin SDK). Double verrou drapeau+droit.
    match /mnt_watches/{uid}       { allow read: if mntEnabled() && canRead('maintenance') && request.auth.uid == uid; allow write: if false; }
    // Astreintes (ADR-035) : lecture CALLABLE-ONLY (allow read: false). Le `montant` est une CHARGE
    // CONFIDENTIELLE ; le callable listAstreintes le MASQUE sans le droit `rentabilite`. Une lecture directe
    // (droit `maintenance` seul) exposerait le montant brut → fuite RBAC (même logique qu'ADR-034). Écriture
    // via submitAstreinte / trigger onMntApprovalDecided (Admin SDK).
    match /mnt_astreintes/{id}     { allow read: if false; allow write: if false; }

    // PARTENARIATS & CERTIFICATIONS (par_) — mêmes profils que mnt_* : lecture gatée drapeau parEnabled()
    // + droit `partenariats`, écriture callable-only (write:false). parEnabled() faux ⇒ aucune lecture,
    // quel que soit le rôle : l'ERP reste celui d'avant (ADR-P01). Le référentiel partenaire (par_partners)
    // ne porte AUCUN montant confidentiel → lecture directe (temps réel onSnapshot) autorisée.
    match /par_partners/{id}       { allow read: if parEnabled() && canRead('partenariats'); allow write: if false; }
    // Certifications des ingénieurs (ADR-P03) : RÉFÉRENCENT un consultant (consultantId) sans exposer son
    // CJM (seuls nom/BU/grade dénormalisés). Donnée NON confidentielle → lecture directe gatée
    // drapeau+droit `partenariats`. Écriture callable-only (upsertParCertification valide l'existence du
    // consultant et du catalogue, dérive expiration + statut).
    match /par_certifications/{id} { allow read: if parEnabled() && canRead('partenariats'); allow write: if false; }
    // Assignations de certification (échéances + relances) : donnée non confidentielle → lecture directe
    // gatée drapeau+droit `partenariats`. Écriture callable-only.
    match /par_assignments/{id}    { allow read: if parEnabled() && canRead('partenariats'); allow write: if false; }

    // Config : la matrice de droits est éditée UNIQUEMENT via le callable setPermissions (schéma
    // validé + auditLog) — jamais en écriture directe (une matrice malformée casserait level() pour
    // tous). Lecture par tout utilisateur connecté (nécessaire à la résolution de niveau côté front).
    match /config/permissions { allow read: if isNt360();               allow write: if false; }
    // config/notifications contient l'URL de webhook (sensible) → lecture réservée aux habilitations.
    match /config/notifications { allow read: if canWrite('habilitations'); allow write: if false; }
    // config/outboundWebhooks (Lot 7b) contient l'URL du webhook sortant (sensible) → habilitations.
    match /config/outboundWebhooks { allow read: if canWrite('habilitations'); allow write: if false; }
    // Table d'alias de normalisation clients (nom→nom, donnée NON sensible — les noms clients
    // apparaissent déjà partout, comme fpAliases) : éditée via setClientAliases, LUE au niveau
    // « overview » pour que le filtre client transverse canonicalise EN MIROIR du serveur (sinon
    // une vue filtrée sous-compte vs l'agrégat serveur). L'édition reste réservée à la direction.
    match /config/clientAliases { allow read: if canRead('overview'); allow write: if false; }
    match /config/supplierAliases { allow read: if canRead('fournisseurs'); allow write: if false; }
    // Overlays d'annulation (statut « Annulée » persistant, hors delta) : ids exclus des agrégats,
    // édités via setCancellation. Lisibles AU NIVEAU DU MODULE (cloisonnement) — les commandes à
    // « overview », les factures à « facturation » (pas de fuite de libellé facturation ailleurs).
    match /config/cancelOrders   { allow read: if canRead('overview');    allow write: if false; }
    match /config/cancelInvoices { allow read: if canRead('facturation'); allow write: if false; }
    // Réconciliation de N° FP (opp→P&L) : une map de N° FP vers N° FP (donnée non sensible, les FP
    // apparaissent déjà dans de nombreuses vues) ; lisible par le carnet (overview), écrite par le
    // callable setFpAlias (Admin SDK, droit « import »).
    match /config/fpAliases      { allow read: if canRead('overview');    allow write: if false; }
    // Rapprochement DC → N° FP (BC fournisseur Odoo, ADR-054) : les clés SONT des DC (identifiants
    // procurement) → cloisonné au data-steward (droit « import », qui édite le rapprochement via setDcAlias).
    match /config/dcAliases      { allow read: if canRead('import');      allow write: if false; }
    // Liens BC↔ClickUp : les clés de la map SONT des n° de BC fournisseurs (safeId réversible) →
    // donnée procurement, cloisonnée au module « bc » (cf. audit intégral R1 : ce doc était dans
    // l'allowlist config/* world-readable, exposant les n° BC aux rôles bc:none / fournisseurs:none).
    match /config/clickupBcLinks { allow read: if canRead('bc'); allow write: if false; }
    // Drapeau du module Contrats de maintenance : booléen NON sensible, lu par tout utilisateur
    // provisionné (App décide la visibilité de l'onglet). Écrit via callable (jamais en direct).
    match /config/mntFeature     { allow read: if isNt360(); allow write: if false; }
    // Calendrier SLA (ADR-P23) : fuseau/fériés/fenêtre B2B. Lu par le module maintenance (horloge SLA),
    // écrit via callable setMntCalendar (droit maintenance en écriture) → write:false ici.
    match /config/mntCalendar    { allow read: if canRead('maintenance'); allow write: if false; }
    // Drapeau « Vérité du coût » (ADR-P21) : SOA depuis factures fournisseur réelles. Même patron que mntFeature.
    match /config/soaFeature     { allow read: if isNt360(); allow write: if false; }
    // Modèle de coût « marge nette » (ADR-P22) : frais de structure (SG&A) en % du CA. Lecture gouvernée
    // rentabilite (donnée sensible : révèle la structure de coût). Écrit via callable setCostModel (direction).
    match /config/costModel      { allow read: if canRead('rentabilite'); allow write: if false; }
    // Drapeau du module Partenariats & Certifications (ADR-P01) : même patron que config/mntFeature.
    match /config/parFeature     { allow read: if isNt360(); allow write: if false; }
    // Overlay de rapprochement fournisseur → constructeur (ADR-P02) : lu par le module (édition/affichage
    // du mapping), gaté drapeau + droit `partenariats`. Écrit via callable setParPartnerMap (write:false).
    match /config/parPartnerMap  { allow read: if parEnabled() && canRead('partenariats'); allow write: if false; }
    // Repli config/* : ALLOWLIST fail-closed (les docs sensibles ont leur propre règle ci-dessus ;
    // un futur doc config/* non listé n'est PAS lisible par défaut). Inclut les référentiels éditables
    // (projectManagers, businessUnits), les taux de change (fxRates) et la config ClickUp NON sensible
    // (enabled/teamId/listId ; le token vit dans Secret Manager, jamais ici) — tous lus par le front.
    // recordAccess (OWD par objet) + security (politique MFA) : lus par tout utilisateur provisionné —
    // le front en a besoin pour cadrer ses requêtes (scoping visibleTo) et proposer l'enrôlement MFA.
    // Non sensibles (des drapeaux public/private + un booléen), écrits via callables (setRecordAccess/
    // setSecurityConfig) — jamais en direct.
    match /config/{id}        { allow read: if isNt360() && id in ['alerts', 'projection', 'periods', 'fiscal', 'projectManagers', 'businessUnits', 'fxRates', 'clickup', 'recordAccess', 'security', 'automations', 'customFields', 'territories', 'teams', 'staffingTargets']; allow write: if false; }

    match /auditLog/{id}      { allow read: if canWrite('habilitations'); allow write: if false; }
    match /opsLog/{id}        { allow read: if canWrite('habilitations'); allow write: if false; }
    // File de rejeu des webhooks sortants (R7) : lisible par les administrateurs (supervision de la
    // livraison / dead-letter) ; écrite uniquement par les Cloud Functions (fireOutbound/retryOutbound).
    match /outboundQueue/{id} { allow read: if canWrite('habilitations'); allow write: if false; }
    // Erreurs client (observabilité front) : lisibles par les administrateurs ; écrites uniquement
    // par la Cloud Function logClientError (jamais en direct).
    match /errorLog/{id}      { allow read: if canWrite('habilitations'); allow write: if false; }
    match /imports/{id}       { allow read: if canWrite('habilitations'); allow write: if false; }
    match /users/{uid}        { allow read: if canWrite('habilitations') || request.auth.uid == uid; allow write: if false; }
  }
}
